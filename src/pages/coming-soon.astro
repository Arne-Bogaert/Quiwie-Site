---
import Layout from '../layouts/layout.astro';
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Quiwie - Spotify Rijpt Nog">
  <style>
    .error-container {
      padding-top: 5vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .temp-logo-wrapper {
      margin-bottom: 30px;
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .temp-logo-text {
      font-family: 'Fredoka', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--text-color);
      letter-spacing: 2px;
      text-transform: uppercase;
      text-align: center;
      line-height: 1.2;
      background: rgba(255, 255, 255, 0.6);
      border: 2px solid var(--warm-brown);
      box-shadow: var(--shadow-soft);
      border-radius: 50%;
      width: 160px;
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: float 5s ease-in-out infinite;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .temp-logo-text:hover {
      transform: rotate(-5deg) scale(1.05);
      box-shadow: var(--shadow-hover);
    }
    .error-message {
      font-family: 'Comic Neue', cursive;
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.7;
      margin-bottom: 40px;
      padding: 0 10px;
      color: var(--text-color);
    }
    .back-button {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background-color: var(--accent-color);
      color: #faf9f6;
      text-decoration: none;
      padding: 16px 32px;
      border-radius: 20px;
      font-family: 'Fredoka', sans-serif;
      font-weight: 600;
      transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: var(--shadow-soft);
      border: 2px solid var(--text-color);
    }
    .back-button:hover {
      background-color: var(--accent-light);
      transform: translate(-2px, -2px) rotate(-2deg);
      box-shadow: var(--shadow-hover);
    }
    .presave-btn {
      background-color: #1db954;
      margin-bottom: 15px;
    }
    .presave-btn:hover {
      background-color: #17a34a;
    }
  </style>

  <div class="container error-container">
    <div class="temp-logo-wrapper">
      <span class="temp-logo-text">Coming<br/>Soon</span>
    </div>

    <h1 class="band-name">Nog even geduld!</h1>

    <div class="error-message">
      <p>Onze excuses voor de radiostilte op Spotify.</p>
      <p>
        We leggen de laatste hand aan de mix zodat jullie binnenkort optimaal
        van ons gejengel kunnen genieten.
      </p>
    </div>

    <a
      href="https://distrokid.com/hyperfollow/quiwie/jouw-link"
      class="back-button presave-btn"
      target="_blank"
    >
      <i class="fab fa-spotify"></i> Pre-save op Spotify
    </a>

    <a href={baseUrl} class="back-button">
      <i class="fas fa-arrow-left"></i> Ik wil terug
    </a>
  </div>
</Layout>
